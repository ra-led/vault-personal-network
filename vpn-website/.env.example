# Required for YooKassa API
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Public base URL where landing is available (used for return_url)
BASE_URL=https://your-site.ru

# Required for persistent payment state
DATABASE_URL=postgresql://vpn:vpn@localhost:5432/vpn_website
# Optional override for docker-compose website container
# WEBSITE_DATABASE_URL=postgresql://vpn:vpn@postgres:5432/vpn_website

# Optional
PORT=8080
TRUST_PROXY=1
YOOKASSA_ENFORCE_IP_FILTER=true
CONTROL_PLANE_API_URL=http://host.docker.internal:8000
CONTROL_PLANE_INTERNAL_TOKEN=replace_me_internal_token
# Set to false only for a payment-recording-only sandbox.
CONTROL_PLANE_SYNC_ENABLED=true
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECT_TIMEOUT_MS=5000
# DB_SSLMODE=require
